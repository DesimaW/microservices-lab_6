{
  "info": {
    "_postman_id": "order-service-collection",
    "name": "Order Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET All Orders",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8082/orders",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["orders"]
        }
      }
    },
    {
      "name": "POST Place Order",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"item\": \"Monitor\",\n  \"quantity\": 1,\n  \"customerId\": \"C123\"\n}"
        },
        "url": {
          "raw": "http://localhost:8082/orders",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["orders"]
        }
      }
    },
    {
      "name": "GET Order By ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8082/orders/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["orders", "1"]
        }
      }
    }
  ]
}