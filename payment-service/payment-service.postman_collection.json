{
  "info": {
    "_postman_id": "payment-service-collection",
    "name": "Payment Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET All Payments",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8083/payments",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8083",
          "path": ["payments"]
        }
      }
    },
    {
      "name": "POST Process Payment",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": 1,\n  \"amount\": 100.0,\n  \"method\": \"CASH\"\n}"
        },
        "url": {
          "raw": "http://localhost:8083/payments/process",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8083",
          "path": ["payments", "process"]
        }
      }
    },
    {
      "name": "GET Payment By ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8083/payments/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8083",
          "path": ["payments", "1"]
        }
      }
    }
  ]
}